    <div>{{! nav }}
      <header class="masthead">
        <h1 class="settitle"><a href="/">{{site-main-title}}</a></h1>
        <blockquote>{{site-sub-title}}</blockquote>
        <form method="get" id="searchform" action="//www.google.com/search">
          <input type="text" class="field" name="q" id="s" placeholder="Search">
          <input type="hidden" name="as_sitesearch" value="{{site-domain}}">
        </form>
      </header>
    </div>
    <div class="node nav">
      <ul>
        {{#nav-categories}}
          <li><a href="{{category-uri}}" id="{{category-name}}_tab">{{category-name}}</a></li>
        {{/nav-categories}}
        <li><a href="/tags/" id="tags_tab">Tags</a></li>
        <li><a href="/about/" id="about_tab">About</a></li>
        <li><a href="{{github}}" id="github_tab">GitHub</a></li>
        <li><a href="/rss.xml" id="rss_tab">RSS</a></li>
      </ul>
    </div>
